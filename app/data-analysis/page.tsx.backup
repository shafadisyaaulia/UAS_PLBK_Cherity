              <text x="340" y="280" fill="#6ee7b7" fontSize="10" textAnchor="middle">20</text>
              <text x="490" y="280" fill="#6ee7b7" fontSize="10" textAnchor="middle">30</text>
              
              {/* Titration Curve */}
              <path 
